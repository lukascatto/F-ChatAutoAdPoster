{
  "manifest_version": 3,
  "name": "F-Chat Auto-Advertiser",
  "version": "1.1.0",
  "description": "Automates advertisement postings in F-Chat channels with rate limiting and BBCode preview.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.f-list.net/chat/*",
        "https://www.f-list.net/chat3/*",
        "http://localhost/*"
      ],
      "js": ["content-isolated.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.f-list.net/chat/*",
        "https://www.f-list.net/chat3/*",
        "http://localhost/*"
      ],
      "js": ["content-main.js"],
      "run_at": "document_end",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "scheduler-iframe.html",
        "scheduler-iframe.js"
      ],
      "matches": [
        "https://www.f-list.net/*",
        "http://localhost/*"
      ]
    }
  ]
}
